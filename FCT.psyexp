        <Param val="image_ended_time = globalClock.getTime();&amp;#10;remainder = ((4.0 - image_ended_time) + image_started_time);&amp;#10;responded = 0;&amp;#10;wrongkey = 0;&amp;#10;food_item = trials_health2.thisTrial[&quot;food_item&quot;];&amp;#10;if (key_resp_health2.keys) {&amp;#10;    responded = 1;&amp;#10;    rating_given = key_resp_health2.keys.slice((- 1))[0].toString();&amp;#10;    if ((((((rating_given === &quot;1&quot;) || (rating_given === &quot;2&quot;)) || (rating_given === &quot;3&quot;)) || (rating_given === &quot;4&quot;)) || (rating_given === &quot;5&quot;))) {&amp;#10;        integer_rating = Number.parseInt(rating_given);&amp;#10;        if (((expInfo[&quot;condition&quot;] === 1) || (expInfo[&quot;condition&quot;] === &quot;1&quot;))) {&amp;#10;            health_ratings[food_item] = integer_rating;&amp;#10;        } else {&amp;#10;            health_ratings[food_item] = (6 - integer_rating);&amp;#10;        }&amp;#10;        psychoJS.experiment.addData(&quot;health_rating&quot;, health_ratings[food_item]);&amp;#10;    } else {&amp;#10;        wrongkey = 1;&amp;#10;        remainder = 0;&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="image_ended_time = globalClock.getTime()&amp;#10;remainder = 4.0 - image_ended_time + image_started_time&amp;#10;responded = 0&amp;#10;wrongkey = 0&amp;#10;food_item = trials_health2.thisTrial['food_item']&amp;#10;if key_resp_health2.keys:&amp;#10;    responded = 1&amp;#10;    rating_given = str(key_resp_health2.keys[-1])&amp;#10;    if (rating_given == '1') or (rating_given == '2') or (rating_given == '3') or (rating_given == '4') or (rating_given == '5'):&amp;#10;        integer_rating = int(rating_given)&amp;#10;        if expInfo['condition'] == 1 or expInfo['condition'] == '1':&amp;#10;            health_ratings[food_item] = integer_rating&amp;#10;        else:&amp;#10;            health_ratings[food_item] = (6 - integer_rating)&amp;#10;        thisExp.addData(&quot;health_rating&quot;,health_ratings[food_item])&amp;#10;    else:&amp;#10;        wrongkey = 1&amp;#10;        remainder = 0" valType="extendedCode" updates="constant" name="End Routine"/>
