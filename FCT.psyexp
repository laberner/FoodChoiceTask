      <CodeComponent name="welcome_code" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="health_ratings = {}&amp;#10;taste_ratings = {}&amp;#10;ref_food_from_params = &quot;&quot;&amp;#10;if expInfo['order'] == &quot;TH&quot;:&amp;#10;    health_first = 0&amp;#10;    health_second = 1&amp;#10;else:&amp;#10;    health_first = 1&amp;#10;    health_second = 0&amp;#10;if expInfo['run_h'] == 0 or expInfo['run_h'] == '0':&amp;#10;    health_first = 0&amp;#10;    health_second = 0&amp;#10;if expInfo['run_t'] == 0 or expInfo['run_t'] == '0':&amp;#10;    run_taste = 0&amp;#10;else:&amp;#10;    run_taste = 1&amp;#10;if expInfo['run_c'] == 0 or expInfo['run_c'] == '0':&amp;#10;    run_choice = 0&amp;#10;else:&amp;#10;    run_choice = 1&amp;#10;    ref_food_from_params = expInfo['ref_food_item']&amp;#10;if expInfo['condition'] == 1 or expInfo['condition'] == '1':&amp;#10;    rating_text_taste = &quot;(1) ------ (2) ------ (3) ------ (4) ------ (5)\nBad ----------- Neutral ----------- Good&quot;&amp;#10;    rating_text_health = &quot;(1) ------ (2) ------ (3) ------ (4) ------ (5)\nUnhealthy ----------- Neutral ----------- Healthy&quot;&amp;#10;    health_instruction2 = &quot;You can rate each picture as \&quot;Neutral\&quot;\nor on a scale from \&quot;Unhealthy\&quot; to \&quot;Healthy\&quot;.\n\n(1) ------ (2) ------ (3) ------ (4) ------ (5)\nUnhealthy ----------- Neutral ----------- Healthy\nPress \'space\' to continue.&quot;&amp;#10;    taste_instruction2 = &quot;You can rate each picture as \&quot;Neutral\&quot;\nor on a scale from \&quot;Bad\&quot; to \&quot;Good\&quot;.\n\n(1) ----- (2) ----- (3) ----- (4) ----- (5)\nBad ----------- Neutral ----------- Good\n\nIf you have not eaten that food in a long time\nor never eaten it,\nplease try to remember the last time you ate it\nor think of a comparable food and rate it \nas best you can for how tasty you think it is.\n\nYou can press \'space\' to continue.&quot;&amp;#10;else:&amp;#10;    rating_text_taste = &quot;(1) ------ (2) ------ (3) ------ (4) ------ (5)\nGood ----------- Neutral ----------- Bad&quot;&amp;#10;    rating_text_health = &quot;(1) ------ (2) ------ (3) ------ (4) ------ (5)\nHealthy ----------- Neutral ----------- Unhealthy&quot;&amp;#10;    health_instruction2 = &quot;You can rate each picture as \&quot;Neutral\&quot;\nor on a scale from \&quot;Healthy\&quot; to \&quot;Unhealthy\&quot;.\n\n(1) ------ (2) ------ (3) ------ (4) ------ (5)\nHealthy ----------- Neutral ----------- Unhealthy\nPress \'space\' to continue.&quot;&amp;#10;    taste_instruction2 = &quot;You can rate each picture as \&quot;Neutral\&quot;\nor on a scale from \&quot;Good\&quot; to \&quot;Bad\&quot;.\n\n(1) ----- (2) ----- (3) ----- (4) ----- (5)\nGood ----------- Neutral ----------- Bad\n\nIf you have not eaten that food in a long time\nor never eaten it,\nplease try to remember the last time you ate it\nor think of a comparable food and rate it \nas best you can for how tasty you think it is.\n\nYou can press \'space\' to continue.&quot;&amp;#10;thisExp.addData(&quot;rating_text_health&quot;, rating_text_health)&amp;#10;thisExp.addData(&quot;rating_text_taste&quot;, rating_text_taste)" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="health_ratings = {};&amp;#10;taste_ratings = {};&amp;#10;ref_food_from_params = &quot;&quot;;&amp;#10;if ((expInfo[&quot;order&quot;] === &quot;TH&quot;)) {&amp;#10;    health_first = 0;&amp;#10;    health_second = 1;&amp;#10;} else {&amp;#10;    health_first = 1;&amp;#10;    health_second = 0;&amp;#10;}&amp;#10;if (((expInfo[&quot;run_h&quot;] === 0) || (expInfo[&quot;run_h&quot;] === &quot;0&quot;))) {&amp;#10;    health_first = 0;&amp;#10;    health_second = 0;&amp;#10;}&amp;#10;if (((expInfo[&quot;run_t&quot;] === 0) || (expInfo[&quot;run_t&quot;] === &quot;0&quot;))) {&amp;#10;    run_taste = 0;&amp;#10;} else {&amp;#10;    run_taste = 1;&amp;#10;}&amp;#10;if (((expInfo[&quot;run_c&quot;] === 0) || (expInfo[&quot;run_c&quot;] === &quot;0&quot;))) {&amp;#10;    run_choice = 0;&amp;#10;} else {&amp;#10;    run_choice = 1;&amp;#10;    ref_food_from_params = expInfo[&quot;ref_food_item&quot;];&amp;#10;}&amp;#10;if (((expInfo[&quot;condition&quot;] === 1) || (expInfo[&quot;condition&quot;] === &quot;1&quot;))) {&amp;#10;    rating_text_taste = &quot;(1) ------ (2) ------ (3) ------ (4) ------ (5)\nBad ----------- Neutral ----------- Good&quot;;&amp;#10;    rating_text_health = &quot;(1) ------ (2) ------ (3) ------ (4) ------ (5)\nUnhealthy ----------- Neutral ----------- Healthy&quot;;&amp;#10;    health_instruction2 = &quot;You can rate each picture as \&quot;Neutral\&quot;\nor on a scale from \&quot;Unhealthy\&quot; to \&quot;Healthy\&quot;.\n\n(1) ------ (2) ------ (3) ------ (4) ------ (5)\nUnhealthy ----------- Neutral ----------- Healthy\nPress 'space' to continue.&quot;;&amp;#10;    taste_instruction2 = &quot;You can rate each picture as \&quot;Neutral\&quot;\nor on a scale from \&quot;Bad\&quot; to \&quot;Good\&quot;.\n\n(1) ----- (2) ----- (3) ----- (4) ----- (5)\nBad ----------- Neutral ----------- Good\n\nIf you have not eaten that food in a long time\nor never eaten it,\nplease try to remember the last time you ate it\nor think of a comparable food and rate it \nas best you can for how tasty you think it is.\n\nYou can press 'space' to continue.&quot;;&amp;#10;} else {&amp;#10;    rating_text_taste = &quot;(1) ------ (2) ------ (3) ------ (4) ------ (5)\nGood ----------- Neutral ----------- Bad&quot;;&amp;#10;    rating_text_health = &quot;(1) ------ (2) ------ (3) ------ (4) ------ (5)\nHealthy ----------- Neutral ----------- Unhealthy&quot;;&amp;#10;    health_instruction2 = &quot;You can rate each picture as \&quot;Neutral\&quot;\nor on a scale from \&quot;Healthy\&quot; to \&quot;Unhealthy\&quot;.\n\n(1) ------ (2) ------ (3) ------ (4) ------ (5)\nHealthy ----------- Neutral ----------- Unhealthy\nPress 'space' to continue.&quot;;&amp;#10;    taste_instruction2 = &quot;You can rate each picture as \&quot;Neutral\&quot;\nor on a scale from \&quot;Good\&quot; to \&quot;Bad\&quot;.\n\n(1) ----- (2) ----- (3) ----- (4) ----- (5)\nGood ----------- Neutral ----------- Bad\n\nIf you have not eaten that food in a long time\nor never eaten it,\nplease try to remember the last time you ate it\nor think of a comparable food and rate it \nas best you can for how tasty you think it is.\n\nYou can press 'space' to continue.&quot;;&amp;#10;}&amp;#10;psychoJS.experiment.addData(&quot;rating_text_health&quot;, rating_text_health);&amp;#10;psychoJS.experiment.addData(&quot;rating_text_taste&quot;, rating_text_taste);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
